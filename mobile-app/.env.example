# PlayCompass Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
API_BASE_URL=http://localhost:8000

# Firebase (configured via google-services.json and GoogleService-Info.plist)
# No environment variables needed for Firebase

# Sentry (for crash reporting - Task 10)
SENTRY_DSN=

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true
