{
  "expo": {
    "name": "PlayCompass",
    "slug": "playcompass",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "playcompass",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.playcompass.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.playcompass.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 4,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-google-signin/google-signin",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow PlayCompass to use your location for weather-based activity suggestions."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#7c3aed"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "buildReactNativeFromSource": true
          }
        }
      ],
      "./plugins/withFirebaseModularHeaders"
    ],
    "extra": {
      "eas": {
        "projectId": "490b745a-1b50-4a94-8dee-76ae700fdc38"
      },
      "privacyPolicyUrl": "https://watchlightinteractive.com/playcompass-privacy-policy",
      "termsOfServiceUrl": "https://watchlightinteractive.com/playcompass-terms-of-service"
    },
    "updates": {
      "url": "https://u.expo.dev/490b745a-1b50-4a94-8dee-76ae700fdc38"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "ttague"
  }
}
